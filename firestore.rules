rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity validator: UserProfile
    function isValidUserProfile(data) {
      return data.uid == request.auth.uid
        && data.email is string && data.email.size() > 0 && data.email.size() <= 256
        && data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100
        && data.joinedDate is string
        && data.verifiedStatus is bool
        && data.phone is string && data.phone.size() <= 30
        && data.listingRefs is list;
    }

    // Entity validator: ProductListing
    function isValidProductListing(data) {
      return data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.price is number && data.price >= 0
        && data.category is string && data.category.size() > 0
        && data.location is string && data.location.size() > 0
        && data.sellerId == request.auth.uid
        && data.status in ['active', 'sold', 'inactive']
        && data.images is list && data.images.size() <= 4
        && data.phone is string && data.phone.size() <= 30;
    }

    // Collection: Users
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid) && isValidUserProfile(incoming());
      allow update: if isOwner(uid) && isValidUserProfile(incoming()) 
        && incoming().uid == existing().uid;
      allow delete: if isOwner(uid);
    }

    // Collection: Listings
    match /listings/{id} {
      allow read: if true; // Publicly readable so visitors can search and view listings
      allow create: if isSignedIn() && isValidId(id) && isValidProductListing(incoming());
      allow update: if isSignedIn() && isValidId(id) && isOwner(existing().sellerId) && isValidProductListing(incoming())
        && incoming().sellerId == existing().sellerId
        && incoming().id == existing().id;
      allow delete: if isSignedIn() && isValidId(id) && isOwner(existing().sellerId);
    }
  }
}
